{
  "name": "ai-inventory-frontend-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Repo-level tooling for the Mise frontend monorepo (ADR sync + drift check). The app lives in client/.",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "preview": "npm --prefix client run preview",
    "install:client": "npm --prefix client install",
    "adr:sync": "node scripts/adr-sync.mjs",
    "adr:check": "node scripts/adr-sync.mjs --check"
  }
}
