# Vite exposes client-side variables that start with VITE_.
VITE_API_BASE_URL=http://localhost:5000/api

# Optional: Firebase Auth (shared ADR 0003). Leave unset to run the app
# unauthenticated — apiClient sends requests without a Bearer token and
# AuthContext reports isConfigured: false.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
