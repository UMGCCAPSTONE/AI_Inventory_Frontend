# Vite exposes client-side variables that start with VITE_.
VITE_API_BASE_URL=http://localhost:5000/api

# Serve mock fixtures (src/mocks) instead of empty data while the backend is not
# wired. Leave unset to default to dev-only (on with `npm run dev`, off in the
# production build). Set explicitly to "true" or "false" to override.
# VITE_ENABLE_MOCKS=true
